generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  DEAD
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

enum WorkerStatus {
  IDLE
  BUSY
  OFFLINE
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  projects    Project[]
  jobsCreated Job[]
}

model Project {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  userId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  queues Queue[]

  @@index([userId])
}

model RetryPolicy {
  id          String        @id @default(uuid()) @db.Uuid
  strategy    RetryStrategy
  baseDelayMs Int
  maxRetries  Int
  createdAt   DateTime      @default(now())

  queues Queue[]
}

model Queue {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  projectId        String   @db.Uuid
  retryPolicyId    String?  @db.Uuid
  concurrencyLimit Int
  isPaused         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  retryPolicy RetryPolicy? @relation(fields: [retryPolicyId], references: [id])

  jobs Job[]

  @@index([projectId])
}

model Worker {
  id       String       @id @default(uuid()) @db.Uuid
  hostname String
  version  String
  pid      Int
  status   WorkerStatus @default(IDLE)

  lastHeartbeatAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  executions  JobExecution[]
  claimedJobs Job[]             @relation("ClaimedJobs")
  heartbeats  WorkerHeartbeat[]

  @@index([lastHeartbeatAt])
}

model WorkerHeartbeat {
  id       String   @id @default(uuid()) @db.Uuid
  workerId String   @db.Uuid
  sentAt   DateTime @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([sentAt])
}

model Job {
  id String @id @default(uuid()) @db.Uuid

  queueId     String @db.Uuid
  createdById String @db.Uuid

  type    String
  payload Json

  status   JobStatus   @default(QUEUED)
  priority JobPriority @default(NORMAL)

  scheduledFor DateTime?

  cronExpr       String?
  cronIntervalMs Int?

  batchId String?

  attempt     Int @default(0)
  maxAttempts Int

  idempotencyKey String? @unique

  claimedBy String?   @db.Uuid
  claimedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  queue   Queue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  creator User  @relation(fields: [createdById], references: [id])

  worker Worker? @relation("ClaimedJobs", fields: [claimedBy], references: [id])

  executions JobExecution[]
  logs       JobLog[]
  deadLetter DeadLetterQueue?

  @@index([status, scheduledFor])
  @@index([queueId, status])
  @@index([claimedBy])
}

model JobExecution {
  id String @id @default(uuid()) @db.Uuid

  jobId    String @db.Uuid
  workerId String @db.Uuid

  startedAt  DateTime
  finishedAt DateTime?

  status ExecutionStatus

  durationMs   Int?
  errorMessage String?

  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([workerId])
}

model JobLog {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @db.Uuid
  message   String
  level     LogLevel
  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model DeadLetterQueue {
  id      String   @id @default(uuid()) @db.Uuid
  jobId   String   @unique @db.Uuid
  reason  String
  movedAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}
